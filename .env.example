# ==========================================
# 🚀 NUXT SERVER CONFIGURATION
# ==========================================
# Assessment README'sinde belirtilen default port (Değerlendirici deneyimi için 5173 yapıldı)
PORT=5173

# ==========================================
# 🗄️ DATABASE CONFIGURATION (Mongoose)
# ==========================================
# Local MongoDB veya MongoDB Atlas URI
NUXT_MONGO_URI=mongodb+srv://<user>:<password>@cluster...


# ==========================================
# 🔐 AUTHENTICATION (nuxt-auth-utils)
# ==========================================
# Session datalarını şifrelemek için kullanılan 32+ karakterli secret key.
# Terminalde şu komutla güvenli bir key üretebilirsiniz: openssl rand -base64 32
NUXT_SESSION_PASSWORD=replace-this-with-a-very-long-and-secure-random-string-at-least-32-chars
